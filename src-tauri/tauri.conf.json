{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "touhou-wallpaper",
  "version": "0.1.0",
  "identifier": "com.touhou.wallpaper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "东方演舞壁纸",
        "width": 1100,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
