{
  "name": "touhou-wallpaper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:stop": "python scripts/build/kill_dev_port.py",
    "dev": "npm run dev:stop && vite",
    "dev:autostart:on": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build/register_dev_autostart.ps1",
    "dev:autostart:off": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build/unregister_dev_autostart.ps1",
    "dev:autostart:start": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Start-ScheduledTask -TaskName TouhouWallpaperViteDev\"",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "ci": "npm run check && npm test",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc -b --noEmit && python scripts/verify/verify_m0.py",
    "check:m1": "tsc -b --noEmit && python scripts/verify/verify_m1.py",
    "download:assets": "python scripts/build/download_assets.py",
    "apply:wallpaper": "python scripts/build/apply_wallpaper.py",
    "verify:m0": "python scripts/verify/verify_m0.py",
    "verify:m1": "python scripts/verify/verify_m1.py",
    "check:m2": "tsc -b --noEmit && python scripts/verify/verify_m2.py",
    "verify:m2": "python scripts/verify/verify_m2.py",
    "check:m3": "tsc -b --noEmit && python scripts/verify/verify_m3.py",
    "verify:m3": "python scripts/verify/verify_m3.py",
    "check:m4": "tsc -b --noEmit && python scripts/verify/verify_m4.py",
    "verify:m4": "python scripts/verify/verify_m4.py",
    "check:m5": "tsc -b --noEmit && python scripts/verify/verify_m5.py",
    "verify:m5": "python scripts/verify/verify_m5.py",
    "check:m6": "tsc -b --noEmit && python scripts/verify/verify_m6.py",
    "verify:m6": "python scripts/verify/verify_m6.py",
    "check:m7": "tsc -b --noEmit && python scripts/verify/verify_m7.py",
    "verify:m7": "python scripts/verify/verify_m7.py",
    "check:m8": "tsc -b --noEmit && python scripts/verify/verify_m8.py",
    "verify:m8": "python scripts/verify/verify_m8.py",
    "icon:generate": "python scripts/build/generate_icon.py",
    "check:m9": "tsc -b --noEmit && python scripts/verify/verify_m9.py",
    "verify:m9": "python scripts/verify/verify_m9.py",
    "check:favorites-gallery": "tsc -b --noEmit && python scripts/verify/verify_favorites_gallery.py",
    "verify:favorites-gallery": "python scripts/verify/verify_favorites_gallery.py",
    "check:character-search": "tsc -b --noEmit && python scripts/verify/verify_character_search.py",
    "verify:character-search": "python scripts/verify/verify_character_search.py",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run icon:generate && tauri build && python scripts/build/rename_installer.py"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
